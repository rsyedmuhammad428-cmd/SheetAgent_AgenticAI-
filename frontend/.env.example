# Copy this to .env and fill in values

# Public backend URL for standalone frontend deployments such as
# Vercel → Hugging Face Spaces. Leave empty for local Docker/nginx
# same-origin mode so requests stay relative: /api/chat/, /api/upload/, /ws/:session_id
VITE_API_BASE_URL=

# Example:
# VITE_API_BASE_URL=https://your-username-sheetagent-backend.hf.space
